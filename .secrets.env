#!/usr/bin/env bash
# LAB4 secret environment variables
# Source this file before running terraform_startup.sh or terraform_destroy.sh:
#   source .secrets.env
#
# NEVER commit this file to Git — it is listed in .gitignore.

# Terraform 1.14.6 stable binary installed to ~/bin (shadows Chocolatey alpha)
export PATH="$HOME/bin:$PATH"

# DB password (Tokyo Aurora)
# FIRST_TIME_DB_PASSWORD is used on initial deploy (before Secrets Manager has the secret).
# After first deploy, this should be updated to the value stored in Secrets Manager,
# or left as-is — Aurora will use whatever value Terraform set on creation.
FIRST_TIME_DB_PASSWORD="armag3ddon"

_db_secret=$(aws secretsmanager get-secret-value \
  --secret-id taaops/rds/mysql --region ap-northeast-1 \
  --query SecretString --output text 2>/dev/null || echo "")
if [[ -n "$_db_secret" ]]; then
  export TF_VAR_db_password=$(/c/Python311/python.exe -c "import sys,json; print(json.loads('${_db_secret}')['password'])" 2>/dev/null || echo "$_db_secret")
  echo "  [.secrets.env] DB password loaded from Secrets Manager"
else
  export TF_VAR_db_password="$FIRST_TIME_DB_PASSWORD"
  echo "  [.secrets.env] taaops/rds/mysql not found — using FIRST_TIME_DB_PASSWORD for initial deploy"
fi
unset _db_secret FIRST_TIME_DB_PASSWORD

# VPN Pre-Shared Keys — tunnels 1-4 (AWS <-> GCP TGW HA VPN)
export TF_VAR_aws_gcp_psk_tunnel_1="BtGrGuOlzLE7ViUQK2IEgRYqNRHQMOlT1j6YrRFFU3O7GoM7znhaGq0yzu7Cax17"
export TF_VAR_aws_gcp_psk_tunnel_2="qHy2NKIclQatp4l4zWkQ0uZ9qCxzxYQS4kwJkDYFt9pfCqZdk9KXk42KT09kBgp1"
export TF_VAR_aws_gcp_psk_tunnel_3="HOCRn7neQf01CJ5U5JqYAr51hmF1H8INexczaTgH5Z9R2zRRwanO1fG2zpbrqdKj"
export TF_VAR_aws_gcp_psk_tunnel_4="4pmpGDydYiCspFwIJnkaQ2ECCUZXCQWrmO7W4QafT4ykyP6LezK6WU6TxtcvbCEL"

export TF_VAR_psk_tunnel_1="BtGrGuOlzLE7ViUQK2IEgRYqNRHQMOlT1j6YrRFFU3O7GoM7znhaGq0yzu7Cax17"
export TF_VAR_psk_tunnel_2="qHy2NKIclQatp4l4zWkQ0uZ9qCxzxYQS4kwJkDYFt9pfCqZdk9KXk42KT09kBgp1"
export TF_VAR_psk_tunnel_3="HOCRn7neQf01CJ5U5JqYAr51hmF1H8INexczaTgH5Z9R2zRRwanO1fG2zpbrqdKj"
export TF_VAR_psk_tunnel_4="4pmpGDydYiCspFwIJnkaQ2ECCUZXCQWrmO7W4QafT4ykyP6LezK6WU6TxtcvbCEL"
