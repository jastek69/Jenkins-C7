#!/usr/bin/env bash
# LAB4 secret environment variables — EXAMPLE TEMPLATE
# Copy to .secrets.env and fill in real values:
#   cp .secrets.env.example .secrets.env
#
# .secrets.env is gitignored. This example file is safe to commit.

# DB password (Tokyo Aurora)
export TF_VAR_db_password="REPLACE_WITH_DB_PASSWORD"

# VPN Pre-Shared Keys — tunnels 1-4 (AWS <-> GCP TGW HA VPN)
# Generate with: openssl rand -base64 48
export TF_VAR_aws_gcp_psk_tunnel_1="REPLACE_WITH_PSK_TUNNEL_1"
export TF_VAR_aws_gcp_psk_tunnel_2="REPLACE_WITH_PSK_TUNNEL_2"
export TF_VAR_aws_gcp_psk_tunnel_3="REPLACE_WITH_PSK_TUNNEL_3"
export TF_VAR_aws_gcp_psk_tunnel_4="REPLACE_WITH_PSK_TUNNEL_4"

export TF_VAR_psk_tunnel_1="REPLACE_WITH_PSK_TUNNEL_1"
export TF_VAR_psk_tunnel_2="REPLACE_WITH_PSK_TUNNEL_2"
export TF_VAR_psk_tunnel_3="REPLACE_WITH_PSK_TUNNEL_3"
export TF_VAR_psk_tunnel_4="REPLACE_WITH_PSK_TUNNEL_4"
